<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.lx.mapper.TaskRecordMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="org.lx.entity.TaskRecord">
        <id column="id" property="id" />
        <result column="file_id" property="file_id" />
        <result column="task_type" property="task_type" />
        <result column="task_status" property="task_status" />
        <result column="input_key" property="input_key" />
        <result column="output_key" property="output_key" />
        <result column="error_msg" property="error_msg" />
        <result column="create_time" property="create_time" />
        <result column="finish_time" property="finish_time" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, file_id, task_type, task_status, input_key, output_key, error_msg, create_time, finish_time
    </sql>

</mapper>
